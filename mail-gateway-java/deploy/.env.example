# Public DNS name of your mail API
DOMAIN=mail-api.example.com

# Certbot account email
CERTBOT_EMAIL=ops@example.com

# Mail gateway application settings
PORT=8080
MAIL_GATEWAY_API_KEY=replace-with-long-random-secret
MAIL_GATEWAY_DEFAULT_FROM=Agathaba <devis@agathaba.com>

# SMTP credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user
SMTP_PASSWORD=pass
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_STARTTLS_REQUIRED=false
SMTP_CONNECTION_TIMEOUT=5000
SMTP_TIMEOUT=5000
SMTP_WRITE_TIMEOUT=5000
